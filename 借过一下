function togglePlay() { isPlaying ? pause() : play(); }

/* 频谱波纹 */
const waveCanvas = document.getElementById('waveCanvas');
const waveCtx = waveCanvas.getContext('2d');
let waveData = [];

function initWave() {
  const rect = waveCanvas.parentElement.getBoundingClientRect();
  waveCanvas.width = rect.width;
  waveCanvas.height = rect.height;
  for (let i = 0; i < 64; i++) waveData.push(Math.random() * 25 + 5);
  drawWave();
}

function drawWave() {
  waveCtx.clearRect(0, 0, waveCanvas.width, waveCanvas.height);
  const baseY = waveCanvas.height;

  [{color:'rgba(43,72,104,0.12)',offset:30,amp:1.5,speed:0.6},
   {color:'rgba(54,99,146,0.18)',offset:15,amp:1.0,speed:1.0},
   {color:'rgba(108,154,196,0.12)',offset:5,amp:0.7,speed:1.4}
  ].forEach(layer => {
    waveCtx.beginPath();
    waveCtx.moveTo(0, baseY);
    for (let i = 0; i < 64; i++) {
      waveData[i] += (Math.random() - 0.5) * 4 * layer.speed;
      waveData[i] = Math.max(3, Math.min(40, waveData[i]));
      const x = (i / 63) * waveCanvas.width;
      const y = baseY - waveData[i] * layer.amp - layer.offset;
      if (i === 0) waveCtx.lineTo(x, y);
      else {
        const px = ((i - 1) / 63) * waveCanvas.width;
        const py = baseY - waveData[i - 1] * layer.amp - layer.offset;
        waveCtx.quadraticCurveTo(px, py, (px + x) / 2, (py + y) / 2);
      }
    }
    waveCtx.lineTo(waveCanvas.width, baseY);
    waveCtx.closePath();
    waveCtx.fillStyle = layer.color;
    waveCtx.fill();
  });

  requestAnimationFrame(drawWave);
}

/* ===== 彩虹弹珠粒子 ===== */
const particleCanvas = document.getElementById('particleCanvas');
const pCtx = particleCanvas.getContext('2d');
let particles = [];

function initParticle() {
  const rect = particleCanvas.parentElement.getBoundingClientRect();
  particleCanvas.width = rect.width;
  particleCanvas.height = rect.height;
  drawParticles();
}

function pushMarble(size) {
  const centerX = particleCanvas.width / 2;
  const centerY = particleCanvas.height * 0.4;
  particles.push({
    x: centerX + (Math.random() - 0.5) * 140,
    y: centerY + (Math.random() - 0.5) * 20,
    vx: (Math.random() - 0.5) * 2.5,
    vy: -Math.random() * 4.5 - 1.5,
    size: size,
    gravity: 0.15,
    damping: 0.5,
    rotation: Math.random() * Math.PI * 2,
    rotSpeed: (Math.random() - 0.5) * 0.12,
    hue: Math.random() * 360,
    life: 1,
    decay: 0.003 + Math.random() * 0.002,
    squish: 0,
    settled: false,
    bounces: 0,
    maxBounces: 3 + Math.floor(Math.random() * 3)
  });
}

function spawnMarbles(text) {
  if (!text || !particleCanvas.width) return;
  const centerX = particleCanvas.width / 2;
  const centerY = particleCanvas.height * 0.4;

  const base = Math.floor(text.length * 0.9);
  const totalMarbles = Math.max(0, Math.round(base * (0.2 + Math.random() * 1.0)));

  let sizeRange, tier;
  if (totalMarbles <= 2) {
    sizeRange = [6, 11]; tier = 'no';
  } else if (totalMarbles >= 11) {
    sizeRange = [2, 5]; tier = 'perfect';
  } else {
    sizeRange = [3, 8]; tier = 'normal';
  }

  for (let i = 0; i < totalMarbles; i++) {
    pushMarble(sizeRange[0] + Math.random() * (sizeRange[1] - sizeRange[0]));
  }

  return tier;
}

function startPerfectSpray() {
  if (sprayInterval) { clearInterval(sprayInterval); sprayInterval = null; }
  let sprayCount = 0;
  const maxSprays = 50;
  sprayInterval = setInterval(() => {
    sprayCount++;
    const batch = 8 + Math.floor(Math.random() * 8);
    for (let i = 0; i < batch; i++) {
      pushMarble(2 + Math.random() * 3);
    }
    if (sprayCount >= maxSprays) {
      clearInterval(sprayInterval);
      sprayInterval = null;
    }
  }, 100);
}

function drawParticles() {
  if (!particleCanvas.width) { requestAnimationFrame(drawParticles); return; }

  pCtx.clearRect(0, 0, particleCanvas.width, particleCanvas.height);
  const groundY = particleCanvas.height * 0.82;

  pCtx.strokeStyle = 'rgba(108,154,196,0.06)';
  pCtx.lineWidth = 1;
  pCtx.beginPath();
  pCtx.moveTo(0, groundY);
  pCtx.lineTo(particleCanvas.width, groundY);
  pCtx.stroke();

  particles = particles.filter(p => p.life > 0);

  particles.forEach(p => {
    if (!p.settled) {
      p.vy += p.gravity;
      p.x += p.vx;
      p.y += p.vy;
      p.rotation += p.rotSpeed;

      if (p.y + p.size >= groundY) {
        p.y = groundY - p.size;
        p.vy *= -p.damping;
        p.vx *= 0.9;
        p.bounces++;
        p.squish = Math.min(0.5, Math.abs(p.vy) * 0.06);
        p.rotSpeed *= 0.85;

        if (Math.abs(p.vy) < 0.4 || p.bounces >= p.maxBounces) {
          p.settled = true;
          p.squish = 0;
          p.vx = 0;
          p.vy = 0;
        }
      } else {
        p.squish *= 0.9;
      }
    }

    p.life -= p.settled ? p.decay * 0.5 : p.decay;
    const alpha = Math.max(0, p.life);
    if (alpha <= 0) return;

    pCtx.save();
    pCtx.translate(p.x, p.y);
    pCtx.rotate(p.rotation);
    const sx = 1 + p.squish * 0.3;
    const sy = 1 - p.squish * 0.4;
    pCtx.scale(sx, sy);

    const grad = pCtx.createRadialGradient(-p.size*0.3, -p.size*0.3, p.size*0.1, 0, 0, p.size);
    const brightHue = p.hue + (Math.random() - 0.5) * 60;
    grad.addColorStop(0, `hsla(${brightHue}, 100%, 92%, ${alpha})`);
    grad.addColorStop(0.2, `hsla(${brightHue}, 95%, 78%, ${alpha*0.95})`);
    grad.addColorStop(0.5, `hsla(${brightHue - 5}, 90%, 58%, ${alpha*0.85})`);
    grad.addColorStop(1, `hsla(${brightHue + 15}, 85%, 40%, ${alpha*0.65})`);

    pCtx.beginPath();
    pCtx.arc(0, 0, p.size, 0, Math.PI*2);
    pCtx.fillStyle = grad;
    pCtx.fill();

    pCtx.shadowColor = `hsla(${brightHue}, 100%, 75%, ${alpha*0.6})`;
    pCtx.shadowBlur = p.size * 3.5;
    pCtx.beginPath();
    pCtx.arc(0, 0, p.size * 0.6, 0, Math.PI*2);
    pCtx.fillStyle = `hsla(${brightHue}, 100%, 85%, ${alpha*0.5})`;
    pCtx.fill();
    pCtx.shadowBlur = 0;

    pCtx.beginPath();
    pCtx.arc(-p.size*0.28, -p.size*0.28, p.size*0.4, 0, Math.PI*2);
    pCtx.fillStyle = `rgba(255,255,255,${alpha*0.8})`;
    pCtx.fill();

    pCtx.restore();
  });

  requestAnimationFrame(drawParticles);
}

function triggerTierEffect(tier) {
  if (tier === 'normal') {
    return;
  } else if (tier === 'no') {
    lyricsSection.classList.remove('tier-no');
    void lyricsSection.offsetWidth;
    lyricsSection.classList.add('tier-no');
    setTimeout(() => lyricsSection.classList.remove('tier-no'), 600);

    const flash = document.createElement('div');
    flash.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:radial-gradient(circle at 50% 42%, rgba(167,139,218,0.35) 0%, transparent 70%);pointer-events:none;z-index:150;animation:flash-wow 0.5s ease-out forwards;';
    document.body.appendChild(flash);
    setTimeout(() => flash.remove(), 550);

  } else if (tier === 'perfect') {
    document.body.classList.remove('tier-perfect');
    void document.body.offsetWidth;
    document.body.classList.add('tier-perfect');
    setTimeout(() => document.body.classList.remove('tier-perfect'), 550);

    const badge = document.createElement('div');
    badge.className = 'perfect-badge';
    badge.textContent = '✨ perfect';
    document.body.appendChild(badge);
    setTimeout(() => badge.remove(), 1500);

    startPerfectSpray();
  }
}

/* 歌词逻辑 */
function findLine(time) {
  if (time < lyricsData[0].t) return -1;
  for (let i = lyricsData.length - 1; i >= 0; i--) {
    if (time >= lyricsData[i].t) return i;
  }
  return -1;
}

function renderLine(text) {
  lyricCurrent.innerHTML = '';
  lyricCurrent.classList.remove('dissolving');
  text.split('').forEach((char, i) => {
    const span = document.createElement('span');
    span.className = 'lyric-char';
    span.textContent = char;
    span.style.setProperty('--char-delay', `${i * 50}ms`);
    lyricCurrent.appendChild(span);
  });
  requestAnimationFrame(() => lyricCurrent.classList.add('active'));
}

function switchLine(newIdx) {
  if (newIdx === currentLineIndex) return;

  if (currentLineIndex >= 0) {
    const tier = spawnMarbles(lyricsData[currentLineIndex].l);
    triggerTierEffect(tier);
  }

  if (currentLineIndex >= 0) {
    lyricCurrent.classList.add('dissolving');
    lyricCurrent.classList.remove('active');
  }

  currentLineIndex = newIdx;

  setTimeout(() => {
    renderLine(lyricsData[newIdx].l);

    if (newIdx > 0) {
      lyricPrev.textContent = lyricsData[newIdx - 1].l;
      lyricPrev.style.opacity = '1';
    } else {
      lyricPrev.textContent = '';
    }

    if (newIdx < lyricsData.length - 1) {
      lyricNext.textContent = lyricsData[newIdx + 1].l;
    } else {
      lyricNext.textContent = '';
    }
  }, currentLineIndex > 0 ? 350 : 0);
}

function play() {
  audio.play().then(() => {
    isPlaying = true;
    iconPlay.style.display = 'none';
    iconPause.style.display = 'block';
    albumCover.classList.remove('paused');
  }).catch(e => console.log('播放失败', e));
}

function pause() {
  audio.pause();
  isPlaying = false;
  iconPlay.style.display = 'block';
  iconPause.style.display = 'none';
  albumCover.classList.add('paused');
}

function fmt(s) {
  return `${Math.floor(s/60)}:${Math.floor(s%60).toString().padStart(2,'0')}`;
}

playBtn.addEventListener('click', () => isPlaying ? pause() : play());
prevBtn.addEventListener('click', () => { audio.currentTime = 0; if (isPlaying) play(); });
nextBtn.addEventListener('click', () => { audio.currentTime = audio.duration; });

audio.addEventListener('loadedmetadata', () => {
  timeTotal.textContent = fmt(audio.duration);
});

audio.addEventListener('timeupdate', () => {
  const pct = (audio.currentTime / audio.duration) * 100 || 0;
  progressFill.style.width = pct + '%';
  progressThumb.style.left = pct + '%';
  timeCurrent.textContent = fmt(audio.currentTime);
  const idx = findLine(audio.currentTime);
  if (idx >= 0 && idx !== currentLineIndex) switchLine(idx);
});

let dragging = false;
progressBar.addEventListener('touchstart', e => { dragging = true; seek(e); }, {passive:true});
progressBar.addEventListener('touchmove', e => { if (dragging) seek(e); }, {passive:true});
progressBar.addEventListener('touchend', () => { dragging = false; });
progressBar.addEventListener('click', e => {
  const r = progressBar.getBoundingClientRect();
  audio.currentTime = ((e.clientX - r.left) / r.width) * audio.duration;
});

function seek(e) {
  const t = e.touches[0];
  const r = progressBar.getBoundingClientRect();
  audio.currentTime = Math.max(0, Math.min(1, (t.clientX - r.left) / r.width)) * audio.duration;
}

initWave();
initParticle();
</script>
